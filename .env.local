ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres123@db:5432/examdb

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

NEXT_PUBLIC_API_URL=http://localhost:8000
