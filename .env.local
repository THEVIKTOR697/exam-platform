ENVIRONMENT=dev
APP_NAME=exam-platform
DEBUG=true

# ========================

# DATABASE (LOCAL DEV)

# ========================
TOKEN_SECRET_KEY="SUPER_SECRET_KEY_CAMBIALO"

#LOCAL DEV
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxx

STRIPE_SUCCESS_URL=http://localhost:3000/success
